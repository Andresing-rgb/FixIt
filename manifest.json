{
  "manifest_version": 3,
  "name": "FixIt-Gestor de Motivos de Rechazo",
  "version": "1.0.0",
  "description": "Gestor de plantillas para motivos de rechazo en trámites de Apostilla y Legalización",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "mac": "Command+Q"
      },
      "description": "Abrir App de Motivos de Rechazo"
    }
  }
}